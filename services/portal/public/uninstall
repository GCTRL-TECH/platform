#!/usr/bin/env bash
# Ground Control (GCTRL) Uninstaller
#
#   curl -fsSL https://gctrl.tech/uninstall | bash               # safe: keep data
#   curl -fsSL https://gctrl.tech/uninstall | bash -s -- --purge  # COMPLETE wipe
#
# Default mode stops GCTRL and removes its images but PRESERVES your data
# (Postgres / Neo4j / Qdrant volumes + ~/gctrl/data) so you can reinstall later.
#
# --purge (a.k.a. --all, or GCTRL_PURGE=1) does a COMPLETE removal - every
# container, named volume (ALL knowledge-graph data), image, the docker network,
# and the entire install directory - leaving the host as if GCTRL was never
# installed. Use this to test a clean from-zero reinstall.
set -euo pipefail

INSTALL_DIR="${GCTRL_INSTALL_DIR:-${HOME}/gctrl}"
API_URL="${GCTRL_API_URL:-https://api.gctrl.tech}"
COMPOSE="${INSTALL_DIR}/docker-compose.yml"
OVERRIDE="${INSTALL_DIR}/docker-compose.override.yml"
ENV_FILE="${INSTALL_DIR}/.env"

RED='\033[0;31m'; YELLOW='\033[1;33m'; GREEN='\033[0;32m'; BLUE='\033[0;34m'; NC='\033[0m'
info()    { echo -e "${BLUE}[GCTRL]${NC} $1"; }
warn()    { echo -e "${YELLOW}[GCTRL]${NC} $1"; }
success() { echo -e "${GREEN}[GCTRL]${NC} $1"; }

# ── Parse mode ────────────────────────────────────────────────────────────────
PURGE=0
[ "${GCTRL_PURGE:-0}" = "1" ] && PURGE=1
for arg in "$@"; do
  case "$arg" in
    --purge|--all|--complete) PURGE=1 ;;
    --keep-data|--safe)       PURGE=0 ;;
    --yes|-y)                 GCTRL_YES=1 ;;
  esac
done

# Ask for a typed confirmation word. Reads from /dev/tty so it also works when
# the script itself arrives on stdin (curl ... | bash) - a plain `read` would
# consume the next script line there and silently abort. GCTRL_YES=1 (or
# --yes) skips the prompt for scripted/CI use.
confirm_word() { # $1=prompt  $2=required word
  [ "${GCTRL_YES:-0}" = "1" ] && return 0
  local answer=""
  if [ -t 0 ]; then
    read -rp "$1" answer
  elif [ -r /dev/tty ]; then
    read -rp "$1" answer < /dev/tty
  else
    warn "No terminal available for the confirmation prompt."
    warn "Re-run with GCTRL_YES=1 (or --yes) to confirm non-interactively."
    exit 1
  fi
  [ "$answer" = "$2" ]
}

echo -e "${RED}Ground Control Uninstaller${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ "$PURGE" = "1" ]; then
  echo -e "${RED}PURGE MODE - this DESTROYS EVERYTHING:${NC}"
  echo -e "  • all containers + images"
  echo -e "  • ${RED}all data volumes (Postgres, Neo4j, Qdrant, models) - UNRECOVERABLE${NC}"
  echo -e "  • the docker network and ${INSTALL_DIR} (incl. config + data)"
  echo ""
  confirm_word "Type 'purge' to permanently delete everything: " "purge" || { echo "Aborted."; exit 0; }
else
  echo -e "${YELLOW}This stops GCTRL and removes its images.${NC}"
  echo -e "${YELLOW}Your data in ${INSTALL_DIR}/data + volumes is PRESERVED.${NC}"
  echo -e "  (Run with ${BLUE}--purge${NC} to wipe data too for a clean reinstall test.)"
  echo ""
  confirm_word "Type 'uninstall' to confirm: " "uninstall" || { echo "Aborted."; exit 0; }
fi

# Resolve which compose files exist so `down` targets the real project.
COMPOSE_ARGS=()
[ -f "$COMPOSE" ]  && COMPOSE_ARGS+=(-f "$COMPOSE")
[ -f "$OVERRIDE" ] && COMPOSE_ARGS+=(-f "$OVERRIDE")
ENV_ARGS=()
[ -f "$ENV_FILE" ] && ENV_ARGS+=(--env-file "$ENV_FILE")

# ── Deactivate license on the server (best-effort) ─────────────────────────────
if [ -f "${INSTALL_DIR}/config/license.jwt" ]; then
  info "Deactivating license on server..."
  curl -sfX POST "${API_URL}/v1/deactivate" \
    -H "Authorization: Bearer $(cat "${INSTALL_DIR}/config/license.jwt")" &>/dev/null || true
fi

# ── Stop + remove the compose project ──────────────────────────────────────────
if [ ${#COMPOSE_ARGS[@]} -gt 0 ]; then
  if [ "$PURGE" = "1" ]; then
    info "Stopping services and removing containers, volumes and images..."
    docker compose "${COMPOSE_ARGS[@]}" "${ENV_ARGS[@]}" down -v --remove-orphans --rmi all 2>/dev/null || true
  else
    info "Stopping services and removing containers..."
    docker compose "${COMPOSE_ARGS[@]}" "${ENV_ARGS[@]}" down --remove-orphans 2>/dev/null || true
    info "Removing images..."
    docker compose "${COMPOSE_ARGS[@]}" images -q 2>/dev/null | sort -u | xargs -r docker rmi -f 2>/dev/null || true
  fi
else
  warn "No docker-compose.yml at ${INSTALL_DIR} - falling back to name-based cleanup."
fi

# ── Belt-and-suspenders: remove anything named gctrl-* even if compose state is
#    broken/partial. Containers → (in purge) volumes + network. ─────────────────
info "Cleaning up stray GCTRL containers..."
docker ps -aq --filter "name=^gctrl-" 2>/dev/null | xargs -r docker rm -f 2>/dev/null || true

if [ "$PURGE" = "1" ]; then
  info "Removing GCTRL data volumes..."
  # Named volumes are project-prefixed (gctrl_gctrl-pgdata) or bare; match both.
  docker volume ls -q 2>/dev/null | grep -E 'gctrl[_-]' | xargs -r docker volume rm -f 2>/dev/null || true
  info "Removing GCTRL docker network..."
  docker network ls -q --filter "name=gctrl" 2>/dev/null | xargs -r docker network rm 2>/dev/null || true
fi

# ── Remove install directory ───────────────────────────────────────────────────
if [ "$PURGE" = "1" ]; then
  info "Removing ${INSTALL_DIR} (config + data)..."
  rm -rf "${INSTALL_DIR}"
else
  info "Removing config (keeping ${INSTALL_DIR}/data)..."
  rm -f  "${INSTALL_DIR}/docker-compose.yml" "${INSTALL_DIR}/docker-compose.override.yml" \
         "${INSTALL_DIR}/.env" "${INSTALL_DIR}/.previous-images"
  rm -rf "${INSTALL_DIR}/config"
fi

echo ""
if [ "$PURGE" = "1" ]; then
  success "✅ GCTRL completely removed - host is clean."
  echo "  Verify: docker ps -a | grep gctrl    (should be empty)"
  echo "          docker volume ls | grep gctrl (should be empty)"
  echo "          ls ${INSTALL_DIR}             (should not exist)"
  echo "  Fresh install: curl -fsSL https://gctrl.tech/install | bash"
else
  success "✅ GCTRL removed. Data preserved at: ${INSTALL_DIR}/data"
  echo "  Reinstall:  curl -fsSL https://gctrl.tech/install | bash"
  echo "  Full wipe:  curl -fsSL https://gctrl.tech/uninstall | bash -s -- --purge"
fi
