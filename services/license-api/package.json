    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "jose": "^5.3.0",
    "pg": "^8.11.5",
    "resend": "^3.2.0",
    "stripe": "^15.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "extensionsToTreatAsEsm": [".ts"],
