{
  "name": "n8n-nodes-gctrl",
  "version": "1.0.0",
  "description": "n8n community node for Ground Control (GCTRL) - structured knowledge graphs for AI. Extract, query, fuse, and manage knowledge graphs. Use as memory for AI agents.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "gctrl",
    "ground-control",
    "knowledge-graph",
    "rag",
    "ai-memory",
    "entity-extraction",
    "graph-fusion"
  ],
  "license": "MIT",
  "homepage": "https://gctrl.tech",
  "author": {
    "name": "Ground Control",
    "url": "https://gctrl.tech"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gctrl/n8n-nodes-gctrl.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GctrlApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Gctrl/Gctrl.node.js",
      "dist/nodes/GctrlTrigger/GctrlTrigger.node.js",
      "dist/nodes/GctrlMemory/GctrlMemory.node.js",
      "dist/nodes/GctrlKnowledgeTool/GctrlKnowledgeTool.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
